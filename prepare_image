def ensure_not_after_be(text):
    """
    检索字符串中的 '[BE]'和'[DO]'，判断后面是否是 ' not '，如果不是则添加 ' not '。
    """
    be_token = '[BE]'
    do_token = '[DO]'
    not_token = ' not'
    
    # 用来存放处理后的文本
    result_text = ""
    index = 0
    
    while index < len(text):
        # 查找 '[BE]' 和 '[DO]' 的位置
        be_index = text.find(be_token, index)
        do_index = text.find(do_token, index)

        # 如果都找不到，退出循环
        if be_index == -1 and do_index == -1:
            result_text += text[index:]
            break

        # 选择最近的标记
        if be_index != -1 and (do_index == -1 or be_index < do_index):
            # 添加 '[BE]' 之前的文本到结果中
            result_text += text[index:be_index + len(be_token)]
            index = be_index + len(be_token)
            if not text[index:].startswith(not_token):
                result_text += not_token
        elif do_index != -1:
            # 添加 '[DO]' 之前的文本到结果中
            result_text += text[index:do_index + len(do_token)]
            index = do_index + len(do_token)
            if not text[index:].startswith(not_token):
                result_text += not_token
    
    return result_text

