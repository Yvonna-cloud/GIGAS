    def generate_bias_image(self,bias_path, contrast_base_path):
        question_id = str(int(self.batch['question_id'][0]))
        question = str(self.batch['question'][0])
        gth_answer = self.blip_ans_table[question_id]
        ori_image = copy.deepcopy(self.batch['image']).to(self.device)
        prompt = self.generate_prompt(ori_image)
        for iter in range(self.top_k):
            bias_images = self.text_to_image(prompt[iter][0], image=ori_image).images
            bias_image = bias_images[0]
            bias_image_tensor = transform(bias_image).unsqueeze(0).to(self.device)
            pred_ans = self.black_box_predict(bias_image_tensor, question)

            if pred_ans != gth_answer:
                break
        diff = bias_image_tensor - ori_image
        l2_norm = torch.norm(diff, p=2) 
        save_bias(bias_image, bias_path)

        contrast_path = f"{contrast_base_path}/{self.batch['question_id'][0].cpu().numpy()}.png"
        self.save_contrast(bias_image_tensor, pred_ans, contrast_path)
        return bias_image , pred_ans ,l2_norm

    def mlm_task(self,masked_text,image_feature,question,gth_answer):
        context_masked_text = question + masked_text 
        inputs = self.tokenizer_mlm(context_masked_text, return_tensors='pt')
        input_ids = inputs['input_ids'].to(self.device)
        mask_token_index = torch.where(input_ids == self.tokenizer_mlm.mask_token_id)[1]
        ori_sentence = masked_text.replace(self.tokenizer_mlm.mask_token, gth_answer, 1)
        ori_pair = self.itm_task(image_feature,ori_sentence)

        if mask_token_index.numel() == 0:
            return [masked_text for _ in range(self.top_k)]

        # 预测遮掩的词
        with torch.no_grad():
            outputs = self.mlm_model(input_ids=input_ids)

        # 获取 mask token 的预测分数
        mask_token_logits = outputs.logits[0, mask_token_index, :]
        top_k_token_indices = torch.topk(mask_token_logits, 10000, dim=1).indices[0].tolist()
        predicted_tokens = [self.tokenizer_mlm.decode([token_id]).strip() for token_id in top_k_token_indices]
        confidence_scores = torch.softmax(mask_token_logits, dim=1)[0, top_k_token_indices].tolist()
        ori_sentence = masked_text.replace(self.tokenizer_mlm.mask_token, gth_answer, 1)
        ori_pair = self.itm_task(image_feature,ori_sentence)

        # 构建替换后的句子及其置信度
        sentence = []
        for token, confidence in zip(predicted_tokens, confidence_scores):
            if len(sentence) == self.top_k:
                break
            # 生成替换后的句子
            new_sentence = masked_text.replace(self.tokenizer_mlm.mask_token, token, 1)
            # 排除空字符串和相同的gth_answer
            if token.strip() and token != gth_answer:
                pair_rate = self.itm_task(image_feature,new_sentence)
                if pair_rate/ori_pair < self.unpair_rate:
                    sentence.append((new_sentence, confidence,pair_rate,token))

        # 按置信度排序
        sentence.sort(key=lambda x: x[2])
        if len(sentence) < self.top_k:
            last_candidate = sentence[-1] if sentence else masked_text
            sentence.extend([last_candidate] * (self.top_k - len(sentence)))
        return sentence

    def generate_prompt(self,image_feature):
        question_id = str(int(self.batch['question_id'][0]))
        question = str(self.batch['question'][0])
        gth_answer = self.blip_ans_table[question_id]
        masked_text = declarations[question_id]
        label = get_type(question,gth_answer)
        if label == 0 :
                masked_text = masked_text.replace('[MASK]', 'no', 1)
                masked_text = ensure_not_after_be(masked_text)
                masked_text = masked_text + ' ' + "but [MASK] ."
        elif label == 3:
            masked_text = masked_text.replace('[MASK]', 'yes', 1)
            masked_text = masked_text + ' ' + "but [MASK] ."
        elif label == 1:
            masked_text = masked_text.replace('[MASK]', 'no', 1)
            masked_text = masked_text + ' ' + "but [MASK] ."
        elif label == 4 and not gth_answer.strip().lower().startswith('yes'):
            while "[MASK]" in masked_text:
                masked_text = self.mlm_task(masked_text,image_feature,question,gth_answer)
            masked_text = "Because of [MASK] ," + masked_text[0][0]
        new_text = self.mlm_task(masked_text,image_feature,question,gth_answer)
        return new_text
    


